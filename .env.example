# Copy to .env and fill in. Never commit .env.

# --- LLM provider (OpenAI by default; any OpenAI-compatible endpoint works) ---
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- External validation ---
TAVILY_API_KEY=tvly-...

# --- Paths ---
DATA_RAW_PATH=dataset/VF_Hackathon_Dataset_India_Large.xlsx
DATA_DIR=data

# --- Batch extraction ---
# 0 = all rows. Otherwise process a stratified sample of this size.
EXTRACTION_SAMPLE_SIZE=1000

# --- MLflow ---
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=healthmap-agent

# --- CORS for the FastAPI backend (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
