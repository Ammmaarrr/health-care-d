# Copy to .env and fill in. Never commit .env.
# ---------------------------------------------------------------------------
# 1. LLM PROVIDER SWITCH
# ---------------------------------------------------------------------------
# One of: openai (default), databricks, groq, together, fireworks,
#         openrouter, huggingface, custom.
LLM_PROVIDER=openai

# Generic OpenAI-compatible knobs. Empty values = use the provider's
# default from `backend/config.py::_PROVIDER_PROFILES`.
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=
OPENAI_EMBED_MODEL=
OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# 2. DATABRICKS (Agent Bricks / Foundation Model serving + Mosaic AI VS)
# ---------------------------------------------------------------------------
# Required when LLM_PROVIDER=databricks OR when you want the FastAPI
# retriever to query Mosaic AI Vector Search. Generate the token under
# Databricks -> User Settings -> Developer -> Access Tokens.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_LLM_ENDPOINT=databricks-meta-llama-3-1-70b-instruct
DATABRICKS_EMBED_ENDPOINT=databricks-bge-large-en

# Mosaic AI Vector Search. Leave both empty to use the local FAISS index.
VECTOR_SEARCH_ENDPOINT=
VECTOR_SEARCH_INDEX=

# When the chat provider has no embeddings endpoint (Groq, Fireworks,
# OpenRouter, HuggingFace), transparently fall back to OpenAI for
# embeddings. Requires a valid OPENAI_API_KEY.
EMBED_FALLBACK_TO_OPENAI=true

# ---------------------------------------------------------------------------
# 3. EXTERNAL VALIDATION (Tavily, used by validator_agent)
# ---------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...

# ---------------------------------------------------------------------------
# 4. PATHS + BATCH EXTRACTION
# ---------------------------------------------------------------------------
DATA_RAW_PATH=dataset/VF_Hackathon_Dataset_India_Large.xlsx
DATA_DIR=data

# 0 = all rows (use --all flag for the full 10k). Otherwise stratified sample.
EXTRACTION_SAMPLE_SIZE=1000

# ---------------------------------------------------------------------------
# 5. MLFLOW
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=healthmap-agent

# ---------------------------------------------------------------------------
# 6. CORS for the FastAPI backend (comma-separated)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
